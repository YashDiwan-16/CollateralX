            },
            {
                "name": "adminSetPauseFlags",
                "args": [
                    {
                        "type": "uint64",
                        "name": "pauseFlags"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Admin-only replacement of stablecoin control pause flags."
            },
            {
                "name": "mintForVault",
                "args": [
                    {
                        "type": "uint64",
                        "name": "vaultId"
                    },

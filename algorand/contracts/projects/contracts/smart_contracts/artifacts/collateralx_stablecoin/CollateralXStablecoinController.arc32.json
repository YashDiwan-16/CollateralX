                "name": "createApplication",
                "args": [
                    {
                        "type": "address",
                        "name": "admin"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                }
            },
            {
                "name": "initializeStablecoinController",
                "args": [
                    {
                        "type": "uint64",
                        "name": "protocolManagerAppId"
                    },
                    {
                        "type": "uint64",
                        "name": "stableAssetId"
                    },
                    {
                        "type": "uint64",
                        "name": "supplyCeilingMicroStable"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "One-time stablecoin controller initialization by admin."
            },
            {
                "name": "readStablecoinControlState",
                "args": [],
                "readonly": true,
                "returns": {
                    "type": "(address,uint64,uint64,uint64,uint64,uint64,uint64)"
                },
                "desc": "Read stablecoin controller state."
            },
            {
                "name": "adminSetStablecoinConfig",
                "args": [
                    {
                        "type": "uint64",
                        "name": "protocolManagerAppId"
                    },
                    {
                        "type": "uint64",
